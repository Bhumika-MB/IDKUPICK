# Copy this file to .env, then replace the values below.
PORT=5000
FRONTEND_URL=http://localhost:3000
JWT_SECRET=replace-this-with-a-long-random-secret
# Paste your MongoDB Atlas driver connection string here.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/idkupick?retryWrites=true&w=majority
